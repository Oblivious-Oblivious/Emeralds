{
  "scripts": {
    "build": [
      "shards build --release --no-debug",
      "cp bin/emeralds bin/em"
    ],
    "debug": [
      "shards build",
      "cp bin/emeralds bin/em"
    ],
    "all": [
      "rm -rf bin",
      "em build",
      "#chown -R $(whoami) /usr/local/bin",
      "cp bin/em bin/emeralds /usr/local/bin/"
    ],
    "test": "crystal spec ./spec/emeralds.spec.cr",
    "spec": "em test",
    "document": "rm -rf ./docs && crystal docs src/*.cr",
    "clean": "rm -rf bin"
  }
}
