{
  "scripts": {
    "build": [
      "shards build --release --no-debug"
    ],
    "debug": [
      "shards build"
    ],
    "all": [
      "rm -rf bin",
      "em build",
      "cp bin/emeralds bin/em",
      "cp bin/emeralds bin/em /usr/local/bin/"
    ],
    "all-win32": [
      "cmd.exe /c if exist bin rmdir /s /q bin",
      "em build",
      "cmd.exe /c copy /Y bin\\emeralds.exe bin\\em.exe",
      "cmd.exe /c copy /Y bin\\em.exe bin\\emeralds.exe C:\\msys64\\ucrt64\\bin\\"
    ],
    "test": "crystal spec ./spec/emeralds.spec.cr",
    "spec": "em test",
    "document": "rm -rf ./docs && crystal docs src/*.cr",
    "clean": "rm -rf bin"
  }
}
