{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/Oblivious-Oblivious/Emeralds/0.10.0/BUG-01-remove-platform-specific-code/schema/em.schema.json",
  "title": "Emeralds em.json",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "description": "The JSON schema used by editors for em.json autocomplete and validation."
    },
    "name": {
      "type": "string",
      "description": "The name of the Emeralds application or library."
    },
    "version": {
      "type": "string",
      "description": "The project version displayed by em version."
    },
    "license": {
      "type": "string",
      "description": "The project license.",
      "enum": [
        "mit",
        "gpl-v2",
        "apache-v2",
        "gpl-v3",
        "lgpl-v3",
        "mpl-v2",
        "epl-v2",
        "agpl-v3",
        "cc0-v1",
        "cc0-v4"
      ]
    },
    "scripts": {
      "type": "object",
      "description": "Custom commands runnable with em <script>.",
      "additionalProperties": {
        "oneOf": [
          {
            "type": "string"
          },
          {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        ]
      }
    },
    "build-override": {
      "type": "string",
      "description": "A custom build command that overrides the normal Emeralds build."
    },
    "compile-flags": {
      "type": "object",
      "description": "Compiler configuration for debug and release builds.",
      "additionalProperties": false,
      "properties": {
        "cc": {
          "type": "string",
          "description": "The C compiler to use."
        },
        "debug": {
          "$ref": "#/definitions/buildConfig"
        },
        "release": {
          "$ref": "#/definitions/buildConfig"
        }
      }
    },
    "dependencies": {
      "type": "object",
      "description": "Runtime dependencies as GitHub user/repo values.",
      "additionalProperties": {
        "type": "string"
      }
    },
    "dev-dependencies": {
      "type": "object",
      "description": "Development dependencies as GitHub user/repo values.",
      "additionalProperties": {
        "type": "string"
      }
    }
  },
  "definitions": {
    "buildConfig": {
      "type": "object",
      "description": "Compiler flags for one build mode.",
      "additionalProperties": false,
      "properties": {
        "opt": {
          "type": "string",
          "description": "Optimization flag."
        },
        "version": {
          "type": "string",
          "description": "C standard flag."
        },
        "flags": {
          "type": "string",
          "description": "Additional compiler flags."
        },
        "warnings": {
          "type": "string",
          "description": "Warning flags."
        },
        "libs": {
          "type": "string",
          "description": "Additional linked libraries."
        }
      }
    }
  }
}
